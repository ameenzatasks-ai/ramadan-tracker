# Copy this file to `.env` and fill in real values.
# In production (Fly.io), set these with `fly secrets set KEY=value` instead of a file.

# --- Server ---
PORT=4000
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-with-a-long-random-string
# Where the SQLite file lives. Leave blank locally (defaults to server/data.sqlite).
# In production point it at a persistent volume, e.g. /data/data.sqlite
DB_PATH=
# Optional: comma-separated allowed web origins. Leave blank to allow all.
CORS_ORIGIN=

# --- Ramadan window (Gregorian dates) ---
# When the current date is between these (inclusive), goals lock.
# Update each year. Below are Ramadan 1448 AH (2027) estimates — confirm nearer the
# time, as exact dates depend on the moon sighting.
RAMADAN_START_DATE=2027-02-08
RAMADAN_END_DATE=2027-03-09

# --- Email (OTP delivery) ---
# Sender identity shown to users.
EMAIL_FROM_NAME=Ramadan Goal Companion
EMAIL_FROM_ADDRESS=onboarding@resend.dev

# SMTP transport. Leave SMTP_HOST blank in development and the server prints OTP
# codes to its console instead of sending real email.
#
# Recommended for production: Resend (free tier ~100 emails/day). After verifying a
# sender, create an API key and use:
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=resend
#   SMTP_PASS=<your Resend API key>
# (Gmail app-passwords also work but are rate-limited and often land in spam.)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# --- Google Sign-In ---
# OAuth 2.0 Client ID from Google Cloud Console (use the WEB client id).
GOOGLE_CLIENT_ID=

# --- AI (Anthropic Claude) ---
# Optional. If unset, custom-goal expansion uses the rule-based fallback.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
